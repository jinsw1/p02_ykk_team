name: CI/CD Docker

on:
  push:
    branches:
      - main

    # paths:
    #   # - "Dockerfile"
    #   # - "docker-compose.ymal"
    #   # - "compose.ymal"
    #   # - "src/**"
    #   # - "was-server/**"      
    #   - "docker/was_server/**"

  workflow_dispatch:

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-region: ap-northeast-2


      # - name: Debug instance IDs
      #   run: |
      #     echo "INSTANCE_IDS=[${INSTANCE_IDS}]"
      #     aws ec2 describe-instances \
      #       --region ap-northeast-2 \
      #       --instance-ids i-0d50658d420b12328


        
      # 1. Docker Hub 로그인 (CI 단계)
      - name: Login to Docker Hub
        run: |        
          find . -type d -name "fastapi*"
          echo "${{ secrets.DOCKER_PASSWORD }}" | docker login -u "${{ secrets.DOCKER_USERNAME }}" --password-stdin

      # 2. Docker build
      - name: Build Docker image
        run: |
          docker build -t jinsw1/ykk-app-test:1.0 ./docker/was_server/web_service/fastapi_lunch_app

      # 3. Docker push
      - name: Push Docker image
        run: |
          docker push jinsw1/ykk-app-test:1.0

      - name: Find WAS instances
        id: instances
        run: |
          INSTANCE_IDS=$(aws ec2 describe-instances \
            --region ap-northeast-2 \
            --filters \
              "Name=tag:Role,Values=was" \
              "Name=instance-state-name,Values=running" \
            --query "Reservations[].Instances[].InstanceId" \
            --output text | tr '\t' ' ')

          if [ -z "$INSTANCE_IDS" ]; then
            echo "No running WAS instances found"
            exit 1
          fi

          echo "INSTANCE_IDS=$INSTANCE_IDS" >> $GITHUB_ENV
          echo "Found: $INSTANCE_IDS"


      - name: Check SSM managed instances!!!!
        run: |
          aws ssm describe-instance-information \
            --query 'InstanceInformationList[*].[InstanceId,PingStatus]' \
            --output table

      - name: Check SSM parameter!!!!
        run: |
          aws ssm get-parameter \
            --name "/app/db/host" \
            --query "Parameter.Value" \
            --output text       


      - name: Deploy via SSM
        run: |
          DB_HOST=$(aws ssm get-parameter \
            --name "/app/db/host" \
            --query "Parameter.Value" \
            --output text)

          echo "DB_HOST=$DB_HOST"

          aws ssm send-command \
            --region ap-northeast-2 \
            --document-name "AWS-RunShellScript" \
            --instance-ids $INSTANCE_IDS \
            --comment "Docker Deploy" \
            --parameters "commands=[
              \"sudo -iu ykk-admin bash << 'EOF'\",
              \"set -e\",

              \"echo Logging into Docker Hub\",
              \"echo '${{ secrets.DOCKER_PASSWORD }}' | docker login -u '${{ secrets.DOCKER_USERNAME }}' --password-stdin\",

              \"cd /home/ykk-admin/app\",
              \"git fetch origin main\",
              \"git checkout origin/main -- docker/was_server\",

              \"cd /home/ykk-admin/app/docker/was_server\",

              \"echo DB_HOST=$DB_HOST > .env\",

              \"docker pull jinsw1/ykk-app-test:1.0\",
              \"docker compose down || true\",
              \"docker compose up -d --build\",

              \"EOF\"
            ]"