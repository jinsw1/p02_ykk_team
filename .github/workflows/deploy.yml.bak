name: CI/CD Docker

on:
  push:
    branches: [ "main" ]
    # paths:
    #   - "Dockerfile"
    #   - "docker-compose.yml"
    #   - "src/**"
    #   - "app/**"   
  workflow_dispatch:

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      # AWS 인증
      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-region: ap-northeast-2

      # SSM 배포 실행
      - name: Deploy via SSM
        run: |

          aws resourcegroupstaggingapi get-resources \
            --tag-filters Key=Role,Values=was

          aws ssm send-command \
            --region ap-northeast-2 \
            --document-name "AWS-RunShellScript" \
            --targets "Key=tag:Role,Values=was" \
            --comment "Sparse checkout deploy" \
            --parameters 'commands=[
              "set -e",

              "cd /home/ykk-admin/app",

              "echo \"📦 fetch latest changes\"",
              "git fetch origin main",

              "echo \"📂 update sparse directory only\"",
              "git checkout origin/main -- 03_docker/was_server",

              "echo \"🐳 restart docker compose\"",
              "cd 03_docker/was_server",
              "docker compose down || true",
              "docker compose up -d --build",

              "echo \"✅ deploy complete\""
            ]'


      # aws ssm send-command \
